<UserControl x:Class="IndustrialMachineSimulator.UI.Controls.TopHeaderBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IndustrialMachineSimulator.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="38" d:DesignWidth="1920">
    <Grid>
        <Grid Background="#0066FF" Height="auto" VerticalAlignment="Top">
            <!-- Chia grid thanh bar top -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*">

                </ColumnDefinition>
                <ColumnDefinition Width="auto">

                </ColumnDefinition>
                <ColumnDefinition Width="auto">

                </ColumnDefinition>
            </Grid.ColumnDefinitions>
            <TextBlock Text="SM_S928_ROUTER_LASER_SIMULATOR" 
                FontSize="25" FontFamily="Arial" Foreground="White"
/>
            <!-- chia vi tri nut button login va exit -->
            <StackPanel Grid.Column="1" Orientation='Horizontal' VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEA8C;" FontSize="24" Foreground="LightGray" 
                    VerticalAlignment="Center" Margin="0,0,12,0"/>


                <Label Content="{Binding CurrentRoleText}" Foreground="White" 
                VerticalAlignment="Center" FontSize="25" 
                FontFamily="Arial"/>
                <Button Content="LOGIN" 
                 Width="100"
                 Height="35"
                 Background="blue"
                 FontFamily="Arial"
                 FontSize="25"
                 BorderBrush="blue"

                 Foreground="WhiteSmoke"
                 Margin="0,0,12,0"
                 Command="{Binding LoginCommand}"
                 >
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="borderOutline"  Background="{TemplateBinding Background}"
                             BorderBrush="{TemplateBinding BorderBrush}"
                             BorderThickness="1"
                             CornerRadius="10"
                            >
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center">
                                </ContentPresenter>

                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="borderOutline" Property="BorderBrush" Value="White"></Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="borderOutline" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.96" ScaleY="0.96"></ScaleTransform>
                                        </Setter.Value>
                                        
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                        
                    </Button.Template>
                </Button>
            </StackPanel>
            <!-- Nut Exit-->
            <Button Grid.Column="2" Width="50" Height="35" Background="#0066FF">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7E8;" 
                     FontSize="25"
                     Foreground="White">
                </TextBlock>
            </Button>
        </Grid >
    </Grid>
</UserControl>

