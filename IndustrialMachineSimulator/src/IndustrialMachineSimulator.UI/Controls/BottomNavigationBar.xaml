<UserControl x:Class="IndustrialMachineSimulator.UI.Controls.BottomNavigationBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IndustrialMachineSimulator.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="110" d:DesignWidth="1920">
    <Grid>
        <Grid.Resources>
            <!--Set style cho nut menu bottom-->
            <Style x:Key="BottomNavButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="90"></Setter>
                <Setter Property="Height" Value="70"></Setter>
                <Setter Property="Background" Value="White"></Setter>
                <Setter Property="Margin" Value="60,0,0,0"></Setter>
            </Style>
        </Grid.Resources>
        
        <!--Thanh bar menu chinh duoi bottom-->
<StackPanel  Orientation="Horizontal" Background="White" VerticalAlignment="Center">
    <StackPanel Orientation="Vertical">
        <Button  Style="{StaticResource BottomNavButtonStyle}" >
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE10F;" FontSize="50" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
        </Button>
        <Label FontFamily="Arial" FontSize="20" Content="Home" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="60,0,0,5" ></Label>
    </StackPanel>
    <StackPanel Orientation="Vertical">
        <Button  Style="{StaticResource BottomNavButtonStyle}">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7F4;" FontSize="50" Foreground="Black" HorizontalAlignment="Center" Margin="0,15,0,0" ></TextBlock>
        </Button>
        <Label FontFamily="Arial" FontSize="20" Content="Maint" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="60,0,0,5" ></Label>
    </StackPanel>
    <StackPanel Orientation="Vertical">
        <Button  Style="{StaticResource BottomNavButtonStyle}">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="50" Foreground="Black" HorizontalAlignment="Center" Margin="0,10,0,0" ></TextBlock>
        </Button>
        <Label FontFamily="Arial" FontSize="20" Content="Recipe" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="60,0,0,5" ></Label>
    </StackPanel>
    <StackPanel Orientation="Vertical">
        <Button  Style="{StaticResource BottomNavButtonStyle}">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9F9;" FontSize="50" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
        </Button>
        <Label FontFamily="Arial" FontSize="20" Content="Datalog" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="60,0,0,5" ></Label>
    </StackPanel>
    <StackPanel Orientation="Vertical">
        <Button  Style="{StaticResource BottomNavButtonStyle}">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE115;" FontSize="50" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
        </Button>
        <Label FontFamily="Arial" FontSize="20" Content="Setup" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="60,0,0,5" ></Label>
    </StackPanel>
    <StackPanel Orientation="Vertical">
        <Button  Style="{StaticResource BottomNavButtonStyle}">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEA8F;" FontSize="50" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
        </Button>
        <Label FontFamily="Arial" FontSize="20" Content="Alarms" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="60,0,0,5" ></Label>
    </StackPanel>
    <StackPanel Orientation="Vertical">
        <Button  Style="{StaticResource BottomNavButtonStyle}">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xF5ED;" FontSize="50" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
        </Button>
        <Label FontFamily="Arial" FontSize="20" Content="List" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="60,0,0,5" ></Label>
    </StackPanel>
    <StackPanel Orientation="Vertical">
        <Button  Style="{StaticResource BottomNavButtonStyle}">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEB50;" FontSize="50" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
        </Button>
        <Label FontFamily="Arial" FontSize="20" Content="Quick" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="60,0,0,5" ></Label>
    </StackPanel>
    <StackPanel Orientation="Vertical">
        <Button  Style="{StaticResource BottomNavButtonStyle}">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE114;" FontSize="50" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
        </Button>
        <Label FontFamily="Arial" FontSize="20" Content="Vision" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="60,0,0,5" ></Label>
    </StackPanel>
    <StackPanel Orientation="Vertical">
        <Button  Style="{StaticResource BottomNavButtonStyle}">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEA39;" FontSize="50" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
        </Button>
        <Label FontFamily="Arial" FontSize="20" Content="Error" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="60,0,0,5" ></Label>
    </StackPanel>
    <StackPanel Orientation="Vertical">
        <Button  Style="{StaticResource BottomNavButtonStyle}">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xF6FA;" FontSize="50" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
        </Button>
        <Label FontFamily="Arial" FontSize="20" Content="MES" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="60,0,0,5" ></Label>
    </StackPanel>
    <StackPanel Orientation="Vertical">
        <Button  Style="{StaticResource BottomNavButtonStyle}">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xF5F3;" FontSize="50" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
        </Button>
        <Label FontFamily="Arial" FontSize="20" Content="Power" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="60,0,0,5" ></Label>
    </StackPanel>
</StackPanel>
    </Grid>
</UserControl>
